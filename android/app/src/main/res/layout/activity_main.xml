<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg">

    <WebView
        android:id="@+id/webview"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/update_banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_margin="12dp"
        android:padding="14dp"
        android:orientation="vertical"
        android:background="@drawable/banner_bg"
        android:elevation="8dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/update_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text"
            android:textSize="13sp"
            android:textStyle="bold"
            android:text="@string/update_available_title" />

        <ProgressBar
            android:id="@+id/update_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="8dp"
            android:max="100"
            android:progress="0"
            android:progressTint="@color/accent"
            android:progressBackgroundTint="@color/border"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/update_button"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:backgroundTint="@color/accent"
                android:text="@string/update_button" />

            <Button
                android:id="@+id/update_later"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:textColor="@color/muted"
                android:textSize="12sp"
                android:textAllCaps="false"
                android:backgroundTint="@color/border"
                android:text="@string/update_later" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
